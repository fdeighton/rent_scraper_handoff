# -*- mode: python ; coding: utf-8 -*-
# PyInstaller spec for the Fitzrovia Agent (tray app).
#
# Build:  cd agent && pyinstaller build/agent.spec --noconfirm
# Output: agent/dist/FitzroviaAgent/FitzroviaAgent(.exe)
#
# Notes:
#  * Entry point is tray.py (the system-tray app). main.py is the headless variant.
#  * We bundle the WHOLE engine (../code) and the agent package preserving the repo
#    layout under the bundle root, so handlers/comps.py resolves CODE_DIR via
#    sys._MEIPASS (see the `frozen` branch there).
#  * Playwright's Chromium is NOT bundled — it's downloaded on first run (smaller
#    installer). The first scrape triggers `playwright install chromium` if missing.
import os
from PyInstaller.utils.hooks import collect_submodules, collect_data_files

SPECDIR = os.path.dirname(os.path.abspath(SPEC))      # agent/build
AGENT_DIR = os.path.dirname(SPECDIR)                   # agent
REPO = os.path.dirname(AGENT_DIR)                      # repo root
CODE_DIR = os.path.join(REPO, "code")

datas = [
    (os.path.join(AGENT_DIR, "handlers"), "agent/handlers"),
    (os.path.join(AGENT_DIR, "runtime.py"), "agent"),
    (os.path.join(AGENT_DIR, "hub_client.py"), "agent"),
    (os.path.join(AGENT_DIR, "pairing.py"), "agent"),
    (os.path.join(AGENT_DIR, "assets"), "assets"),
    # The scraper engine + per-building recipes (unchanged), mirrored under code/.
    (os.path.join(CODE_DIR, "fetcher.py"), "code"),
    (os.path.join(CODE_DIR, "extractor.py"), "code"),
    (os.path.join(CODE_DIR, "sites"), "code/sites"),
]
# Baked non-secret config (SUPABASE_URL, AGENT_AUTHORIZE_URL). The build script
# writes agent/build/agent.env from build args; secrets are NOT baked (pairing).
_ENV = os.path.join(SPECDIR, "agent.env")
if os.path.exists(_ENV):
    datas.append((_ENV, "."))   # -> sys._MEIPASS/agent.env

# Pull in any extra engine modules + their data the two entrypoints import.
datas += collect_data_files("anthropic")

hiddenimports = (
    collect_submodules("playwright")
    + collect_submodules("curl_cffi")
    + collect_submodules("keyring")
    + collect_submodules("anthropic")
    + ["PIL.Image", "pystray._win32", "pystray._darwin", "pystray._xorg"]
)

ICON = os.path.join(AGENT_DIR, "assets", "icon.ico")  # generated by the build script
icon_arg = ICON if os.path.exists(ICON) else None

a = Analysis(
    [os.path.join(AGENT_DIR, "tray.py")],
    pathex=[AGENT_DIR, CODE_DIR],
    binaries=[],
    datas=datas,
    hiddenimports=hiddenimports,
    hookspath=[],
    runtime_hooks=[],
    excludes=[],
    noarchive=False,
)
pyz = PYZ(a.pure)

exe = EXE(
    pyz, a.scripts, [],
    exclude_binaries=True,
    name="FitzroviaAgent",
    console=False,            # windowed tray app, no terminal
    icon=icon_arg,
)
coll = COLLECT(
    exe, a.binaries, a.datas,
    strip=False, upx=False,
    name="FitzroviaAgent",
)
